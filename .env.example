# Runtime
NODE_ENV=development
HOST=127.0.0.1
PORT=3000
PUBLIC_APP_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Database
MONGO_URI=mongodb://127.0.0.1:27017/gsplay

# Authentication - generate unique high-entropy values; never use these example values
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-refresh-secret
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Provider integrations
STEAM_API_KEY=
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
RETROACHIEVEMENT_USERNAME=
RETROACHIEVEMENT_API_KEY=

# Operations
LOG_LEVEL=info
ENABLE_WORKER=true
UPLOAD_MAX_BYTES=10485760