# Runtime
NODE_ENV=development
HOST=127.0.0.1
PORT=3000
PUBLIC_APP_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Database
MONGO_URI=mongodb://127.0.0.1:27017/gsplay

# Authentication - generate unique high-entropy values; never use these example values
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-refresh-secret
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# Provider integrations
STEAM_API_KEY=
# Twitch application credentials used to obtain the IGDB access token.
# IGDB_CLIENT_ID / IGDB_CLIENT_SECRET remain accepted aliases.
TW_CLIENT_ID=
TW_CLIENT_SECRET=
RETROACHIEVEMENT_USERNAME=
RETROACHIEVEMENT_API_KEY=

# Operations
LOG_LEVEL=info
ENABLE_WORKER=true
UPLOAD_MAX_BYTES=10485760
# IGDB worker protection: one request every 500ms by default (well below the free API rate limit).
IGDB_MIN_INTERVAL_MS=500
IGDB_COOLDOWN_MS=60000
IGDB_MAINTENANCE_MS=900000
IGDB_QUEUE_LIMIT=100
IGDB_MAX_ATTEMPTS=6
# Development recovery for terminal state written by pre-recovery workers. Keep false in production.
IGDB_RECOVER_LEGACY_PERMANENT=true